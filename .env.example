# =============================================
# Suricata Web — 環境變數設定檔
# 複製為 .env 後填入真實值
# 注意：禁止將 .env 提交至版本控制
# =============================================

# ---- NAS 連線設定 ----
NAS_HOST=192.168.22.65
NAS_SHARE=ctc_nas
NAS_USERNAME=ah_user
NAS_PASSWORD=          # 填入 NAS 密碼
NAS_MOUNT_PATH=/mnt/nas

# ---- 應用程式密鑰（JWT 簽署用，請使用 openssl rand -hex 32 產生） ----
SECRET_KEY=changeme

# ---- MySQL 資料庫連線 ----
DATABASE_URL=mysql+aiomysql://suricata:password@127.0.0.1:3306/suricata

# ---- Redis 連線 ----
REDIS_URL=redis://127.0.0.1:6379/0

# ---- GeoIP 資料庫路徑（可選，用於地理分布分析） ----
GEOIP_DB_PATH=/www/wwwroot/web-suricata-test/GeoLite2-City.mmdb

# ---- Celery Worker 並行數 ----
MAX_WORKER_CONCURRENCY=4

# ---- CORS 允許來源（逗號分隔多個域名） ----
ALLOWED_ORIGINS=http://localhost:3000

# ---- JWT Token 過期時間 ----
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
